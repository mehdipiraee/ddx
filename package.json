{
  "name": "ddx",
  "version": "0.1.5",
  "description": "AI-human collaboration tool for maintaining source of truth documentation",
  "main": "dist/index.js",
  "bin": {
    "ddx": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "build:backend": "tsc && chmod +x dist/cli.js",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/cli.js"
  },
  "keywords": ["documentation", "ai", "collaboration", "source-of-truth"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "0.18.0",
    "commander": "11.1.0",
    "dotenv": "16.6.1",
    "js-yaml": "4.1.1",
    "chalk": "4.1.2"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.19.33",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
